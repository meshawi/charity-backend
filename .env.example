# ===========================================
# CHARITY BACKEND ENVIRONMENT VARIABLES
# Copy this to .env and adjust values
# ===========================================

# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=charity_database
DB_USER=charity_user
DB_PASSWORD=charity_password

# JWT
JWT_SECRET=your-secret-key-here

# CORS - Set to true to allow all origins (for LAN/private installations)
# When false, set FRONTEND_URL to allow a specific origin (omit for same-origin only)
CORS_ALLOW_ALL=true
# FRONTEND_URL=http://localhost:5173

# Cookie secure flag - set to true when using HTTPS
COOKIE_SECURE=false

# Super Admin (required for seeding and password recovery)
SUPER_ADMIN_EMAIL=admin@charity.com
SUPER_ADMIN_NAME=مدير النظام
SUPER_ADMIN_NATIONAL_ID=1234567890
SUPER_ADMIN_PASSWORD=admin123

# Document Storage Paths
# Default location: C:\charity-storage (Windows)
# Default location: /tmp/charity-storage (Linux)
# Leave empty to use defaults, or set custom paths:
# DOCUMENTS_BASE_PATH=
# PDF_STORAGE_PATH=
# REPORTS_STORAGE_PATH=
# BACKUPS_PATH=
